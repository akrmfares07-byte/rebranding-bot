import admin from "firebase-admin";

function getEnv(name) {
  const v = process.env[name];
  if (!v) throw new Error(`Missing env: ${name}`);
  return v;
}

if (!admin.apps.length) {
  admin.initializeApp({
    credential: admin.credential.cert({
      projectId: getEnv("FIREBASE_PROJECT_ID"),
      clientEmail: getEnv("FIREBASE_CLIENT_EMAIL"),
      privateKey: getEnv("FIREBASE_PRIVATE_KEY").replace(/\\n/g, "\n")
    })
  });
}

const db = admin.firestore();

function nowIso() {
  return new Date().toISOString();
}

function safeText(v, fallback = "") {
  return typeof v === "string" ? v.trim() : fallback;
}

export async function logAction(source, actorId, action, data = {}) {
  await db.collection("activity_log").add({
    source,
    actorId: String(actorId || ""),
    action,
    data,
    createdAt: nowIso()
  });
}

export async function getStats() {
  const [usersSnap, offersSnap, accountsSnap] = await Promise.all([
    db.collection("users").get().catch(() => ({ size: 0 })),
    db.collection("offers").get().catch(() => ({ size: 0 })),
    db.collection("accounts").get().catch(() => ({ size: 0 }))
  ]);

  return {
    users: usersSnap.size || 0,
    offers: offersSnap.size || 0,
    accounts: accountsSnap.size || 0
  };
}

export async function addUser(data = {}) {
  const name = safeText(data.name, "بدون اسم");
  const phone = safeText(data.phone);
  const note = safeText(data.note);

  const payload = {
    name,
    phone,
    note,
    createdAt: nowIso(),
    updatedAt: nowIso()
  };

  const ref = await db.collection("users").add(payload);
  return { id: ref.id, ...payload };
}

export async function listUsers(limit = 10) {
  const snap = await db.collection("users").limit(limit).get();
  return snap.docs.map(d => ({ id: d.id, ...d.data() }));
}

export async function createOffer(data = {}) {
  const title = safeText(data.title || data.name, "عرض جديد");
  const discount = safeText(data.discount);
  const expiresAt = safeText(data.expiresAt);
  const details = safeText(data.details);

  const payload = {
    title,
    discount,
    details,
    expiresAt,
    active: true,
    createdAt: nowIso(),
    updatedAt: nowIso()
  };

  const ref = await db.collection("offers").add(payload);
  return { id: ref.id, ...payload };
}

export async function listOffers(limit = 10) {
  const snap = await db.collection("offers").limit(limit).get();
  return snap.docs.map(d => ({ id: d.id, ...d.data() }));
}

export async function addAccount(data = {}) {
  const payload = {
    name: safeText(data.name, "حساب جديد"),
    category: safeText(data.category),
    description: safeText(data.description),
    image: safeText(data.image),
    pinned: Boolean(data.pinned),
    active: data.active !== false,
    createdAt: nowIso(),
    updatedAt: nowIso()
  };

  const ref = await db.collection("accounts").add(payload);
  return { id: ref.id, ...payload };
}

export async function searchAccounts(query = "", limit = 10) {
  const q = safeText(query).toLowerCase();
  const snap = await db.collection("accounts").limit(100).get();

  return snap.docs
    .map(d => ({ id: d.id, ...d.data() }))
    .filter(a => {
      const name = String(a.name || "").toLowerCase();
      const cat = String(a.category || "").toLowerCase();
      const desc = String(a.description || "").toLowerCase();
      return name.includes(q) || cat.includes(q) || desc.includes(q);
    })
    .slice(0, limit);
}

export async function setPendingConfirmation(chatId, payload) {
  await db.collection("bot_pending").doc(String(chatId)).set({
    ...payload,
    createdAt: nowIso()
  });
}

export async function getPendingConfirmation(chatId) {
  const doc = await db.collection("bot_pending").doc(String(chatId)).get();
  return doc.exists ? doc.data() : null;
}

export async function clearPendingConfirmation(chatId) {
  await db.collection("bot_pending").doc(String(chatId)).delete().catch(() => {});
}

export async function saveChatMemory(chatId, role, content) {
  await db.collection("bot_memory").add({
    chatId: String(chatId),
    role,
    content: safeText(content),
    createdAt: nowIso()
  });
}

export async function getRecentChatMemory(chatId, limit = 8) {
  const snap = await db
    .collection("bot_memory")
    .where("chatId", "==", String(chatId))
    .get();

  return snap.docs
    .map(d => d.data())
    .sort((a, b) => String(a.createdAt).localeCompare(String(b.createdAt)))
    .slice(-limit)
    .map(x => ({
      role: x.role,
      content: x.content
    }));
}

export async function executeAction(action, data = {}, meta = {}) {
  switch (action) {
    case "stats": {
      const stats = await getStats();
      await logAction(meta.source, meta.actorId, "stats", {});
      return `📊 الإحصائيات:\n👥 Users: ${stats.users}\n🎯 Offers: ${stats.offers}\n🧾 Accounts: ${stats.accounts}`;
    }

    case "add_user": {
      const user = await addUser(data);
      await logAction(meta.source, meta.actorId, "add_user", user);
      return `✅ تم إضافة المستخدم: ${user.name}${user.phone ? `\n📞 ${user.phone}` : ""}`;
    }

    case "list_users": {
      const users = await listUsers(Number(data.limit) || 10);
      if (!users.length) return "مفيش مستخدمين حاليًا.";
      return "👥 المستخدمين:\n" + users.map((u, i) => `${i + 1}) ${u.name}${u.phone ? ` - ${u.phone}` : ""}`).join("\n");
    }

    case "create_offer": {
      const offer = await createOffer(data);
      await logAction(meta.source, meta.actorId, "create_offer", offer);
      return `🎯 تم إنشاء العرض: ${offer.title}${offer.discount ? `\n💸 الخصم: ${offer.discount}` : ""}`;
    }

    case "list_offers": {
      const offers = await listOffers(Number(data.limit) || 10);
      if (!offers.length) return "مفيش عروض حاليًا.";
      return "🎯 العروض:\n" + offers.map((o, i) => `${i + 1}) ${o.title}${o.discount ? ` - ${o.discount}` : ""}`).join("\n");
    }

    case "add_account": {
      const acc = await addAccount(data);
      await logAction(meta.source, meta.actorId, "add_account", acc);
      return `🧾 تم إضافة الحساب: ${acc.name}`;
    }

    case "search_accounts": {
      const results = await searchAccounts(data.query || "", Number(data.limit) || 10);
      if (!results.length) return "ملقتش حسابات مطابقة.";
      return "🔎 النتائج:\n" + results.map((a, i) => `${i + 1}) ${a.name}${a.category ? ` - ${a.category}` : ""}`).join("\n");
    }

    default:
      return "مش لاقي تنفيذ مباشر للطلب ده حاليًا.";
  }
}
