{
  "functions": {
    "api/webhook.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/cron.js": {
      "memory": 256,
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron?type=evening",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/cron?type=dawn",
      "schedule": "0 23 * * *"
    }
  ]
}
