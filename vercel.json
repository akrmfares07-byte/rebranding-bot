{
  "functions": {
    "api/webhook.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/cron.js": {
      "memory": 256,
      "maxDuration": 60
    },
    "api/notify.js": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron?type=evening",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/cron?type=dawn",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/cron?type=basma1",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/cron?type=basma2",
      "schedule": "15 16 * * *"
    }
  ]
}
